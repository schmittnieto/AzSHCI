# ============================================================================
# AzSHCI 01Lab configuration
# ============================================================================
# Copy this file to scripts\01Lab\.env and adjust the values for your
# environment. scripts\01Lab\.env is gitignored and must never be committed.
#
# Load it into your session once, then run the deployment scripts:
#
#     .\scripts\01Lab\Set-LabEnv.ps1
#     .\scripts\01Lab\00_Infra_AzHCI.ps1
#     .\scripts\01Lab\01_DC.ps1
#     .\scripts\01Lab\02_Cluster.ps1
#
# The 01Lab scripts read these AZSHCI_* variables from the session. They also
# call Set-LabEnv.ps1 automatically if you forget to load it first.
#
# 00_AzurePreRequisites.ps1 is fully interactive (it selects subscription,
# resource group and principal through prompts) so it does not use this file.
#
# Rules:
#   - One KEY=VALUE per line.
#   - Lines starting with # are comments. Keep notes on their own line.
#   - Surrounding single or double quotes are removed when the value is read.
# ----------------------------------------------------------------------------

# --- Azure subscription and tenant (02_Cluster, 03_TroubleshootingExtensions)
# REQUIRED before running 02_Cluster.ps1. Leave empty to let
# 03_TroubleshootingExtensions.ps1 select the subscription interactively.
AZSHCI_SUBSCRIPTION_ID=""
AZSHCI_TENANT_ID=""
AZSHCI_LOCATION="westeurope"
AZSHCI_CLOUD="AzureCloud"
AZSHCI_RESOURCE_GROUP="rg-azlocal-lab"

# --- Service Principal for Arc registration (02_Cluster, 03 troubleshooting)
# Generated by 00_AzurePreRequisites.ps1. Leave both empty to fall back to an
# interactive device code login on the node.
AZSHCI_SPN_APP_ID=""
AZSHCI_SPN_SECRET=""

# --- Local administrator created during the manual OS install (01_DC, 02_Cluster)
# Credentials used to reach DC and AZLN01 over Hyper-V PowerShell Direct.
AZSHCI_DEFAULT_ADMIN_USER="Administrator"
AZSHCI_DEFAULT_ADMIN_PASSWORD="Start#1234"

# --- Domain Controller AD / LCM user (01_DC)
AZSHCI_DC_LCM_USER="hciadmin"
AZSHCI_DC_LCM_PASSWORD="dgemsc#utquMHDHp3M"

# --- Cluster node local setup user (02_Cluster)
AZSHCI_NODE_SETUP_USER="Setupuser"
AZSHCI_NODE_SETUP_PASSWORD="dgemsc#utquMHDHp3M"

# --- Active Directory domain (01_DC)
AZSHCI_DOMAIN_NAME="azurelocal.local"
AZSHCI_DOMAIN_NETBIOS="AZURELOCAL"
AZSHCI_DNS_FORWARDER="8.8.8.8"
# Run "Get-TimeZone -ListAvailable" on the host to list valid time zone ids.
AZSHCI_DC_TIMEZONE="W. Europe Standard Time"

# --- Lab networking (00_Infra_AzHCI, 01_DC, 02_Cluster, 99_Offboarding)
AZSHCI_VSWITCH_NAME="azurelocal"
AZSHCI_NAT_NAME="azurelocal"
AZSHCI_LAB_SUBNET="172.19.18.0/24"
AZSHCI_LAB_GATEWAY="172.19.18.1"
# DC_IP is the Domain Controller address and is also used as the DNS server that
# the cluster node points to.
AZSHCI_DC_IP="172.19.18.2"
AZSHCI_NODE_IP="172.19.18.10"
AZSHCI_MGMT_NIC1="MGMT1"
AZSHCI_MGMT_NIC2="MGMT2"

# --- VM names (00_Infra_AzHCI, 01_DC, 02_Cluster, 99_Offboarding)
AZSHCI_HCI_VM_NAME="AZLN01"
AZSHCI_DC_VM_NAME="DC"

# --- Paths and ISOs (00_Infra_AzHCI, 99_Offboarding)
AZSHCI_LAB_ROOT_FOLDER="E:\AzureLocalLab"
AZSHCI_ISO_PATH_HCI="E:\ISO\AzureLocal24H2.iso"
AZSHCI_ISO_PATH_DC="E:\ISO\WS2025.iso"

# --- HCI node VM sizing (00_Infra_AzHCI)
AZSHCI_HCI_VM_MEMORY_GB="96"
AZSHCI_HCI_VM_PROCESSORS="32"
AZSHCI_HCI_OS_DISK_GB="127"
AZSHCI_HCI_S2D_DISK_GB="1024"
AZSHCI_HCI_S2D_DISK_COUNT="2"

# --- Domain Controller VM sizing (00_Infra_AzHCI)
AZSHCI_DC_VM_MEMORY_GB="4"
AZSHCI_DC_VM_PROCESSORS="4"
AZSHCI_DC_OS_DISK_GB="60"

# --- Domain Controller sleep timers in seconds (01_DC)
AZSHCI_DC_SLEEP_RENAME="20"
AZSHCI_DC_SLEEP_DOMAIN="360"
AZSHCI_DC_SLEEP_UPDATES="240"

# --- Cluster node sleep timers in seconds and Arc retry (02_Cluster)
AZSHCI_NODE_SLEEP_RESTART="60"
AZSHCI_NODE_SLEEP_FEATURES="60"
AZSHCI_NODE_SLEEP_MODULES="60"
AZSHCI_ARC_RETRY_COUNT="3"
AZSHCI_ARC_SLEEP_BOOTSTRAP="30"
