# terraform.tfvars.example
#
# Copy this file to terraform.tfvars and fill in every value marked with
# TODO before running terraform plan or terraform apply.
#
# IMPORTANT: terraform.tfvars contains sensitive values (passwords, secrets).
# It is listed in .gitignore — never commit the populated file to source control.
#
# ---------------------------------------------------------------------------
# DEPLOYMENT FLOW
#
# Single apply (recommended, is_exported = true):
#   terraform init
#   terraform plan
#   terraform apply
#   Creates the Key Vault, witness storage account, and submits the deployment
#   with deploymentMode = "Deploy". Azure validates the configuration internally
#   before starting the full cluster provisioning (~30-60 minutes).
#
# Optional validate-only run (is_exported = false):
#   Set is_exported = false below, then run terraform apply.
#   Azure validates settings and surfaces errors (~10 minutes) without starting
#   provisioning. Change back to true and run terraform apply again to deploy.
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# Module toggle
# ---------------------------------------------------------------------------

# Set to false before terraform destroy when the Arc node has been manually
# deleted from Azure. This skips the cluster module entirely (including the
# Arc machine data source lookup that fails when the node is gone).
enable_cluster_module = true

# ---------------------------------------------------------------------------
# Azure subscription and resource group
# ---------------------------------------------------------------------------

# TODO: replace with your Azure subscription ID
subscription_id = "00000000-0000-0000-0000-000000000000"

# Resource group created (or selected) by scripts/01Lab/00_AzurePreRequisites.ps1
resource_group_name = "rg-azlocal-lab"

# ---------------------------------------------------------------------------
# Cluster identity
# ---------------------------------------------------------------------------

# cluster_name becomes both the Azure resource name and the internal cluster name.
# site_id is used as namingPrefix (matches ARM's namingPrefix, e.g. "HCI01").
cluster_name         = "azure-local"
site_id              = "HCI01"
custom_location_name = "azlocal-customlocation"

# ---------------------------------------------------------------------------
# Active Directory
# ---------------------------------------------------------------------------

# Domain promoted by scripts/01Lab/01_DC.ps1
domain_fqdn = "azurelocal.local"

# OU pre-created by New-HciAdObjectsPreCreation in 01_DC.ps1
adou_path = "OU=HCI,OU=Servers,OU=_LAB,DC=azurelocal,DC=local"

# ---------------------------------------------------------------------------
# Credentials
#
# WARNING: these are intentional lab defaults. Change them before running
# and never commit real credentials to source control.
# ---------------------------------------------------------------------------

# LCM deployment user created inside the domain by 01_DC.ps1
deployment_user          = "hciadmin"
deployment_user_password = "dgemsc#utquMHDHp3M"

# Local administrator account on the Azure Local node.
# Setupuser is created by 02_Cluster.ps1 (not the built-in Administrator).
local_admin_user     = "Setupuser"
local_admin_password = "dgemsc#utquMHDHp3M"

# ---------------------------------------------------------------------------
# Network
#
# Values must match the static IP configuration applied to the node by
# scripts/01Lab/02_Cluster.ps1.
# The starting/ending range provides infrastructure IPs for management
# VIPs and load balancer addresses. Keep it outside the node IP (.10).
# ---------------------------------------------------------------------------

default_gateway  = "172.19.18.1"
dns_servers      = ["172.19.18.2"]
starting_address = "172.19.18.20"
# Azure Local requires ~6 infrastructure IPs for single-node deployments.
# This lab reserves 10 (.20–.30) to simplify the deployment.
ending_address   = "172.19.18.30"
subnet_mask      = "255.255.255.0"

# ---------------------------------------------------------------------------
# Servers
#
# One entry per Arc-registered node. Single-node lab: only AZLN01.
# ---------------------------------------------------------------------------

servers = [
  {
    name        = "AZLN01"
    ipv4Address = "172.19.18.10"
  }
]

# ---------------------------------------------------------------------------
# Service principals
# ---------------------------------------------------------------------------

# SPN created by scripts/01Lab/00_AzurePreRequisites.ps1.
# Stored as the DefaultARBApplication secret in Key Vault (base64 "id:secret").
# Azure Local LCM uses this credential to authenticate the Arc Resource Bridge
# (custom location management plane) to Azure during and after deployment.
# TODO: replace with the AppId and secret from 00_AzurePreRequisites.ps1 output
service_principal_id     = "00000000-0000-0000-0000-000000000000"
service_principal_secret = "your-spn-client-secret"

# Object ID of the built-in Microsoft.AzureStackHCI resource provider SPN.
# Retrieve it with (requires Az PowerShell):
#   (Get-AzADServicePrincipal -ApplicationId "1412d89f-b8a8-4111-b4fd-e82905cbd85d").Id
# TODO: replace with the value from the command above
rp_service_principal_object_id = "00000000-0000-0000-0000-000000000000"

# ---------------------------------------------------------------------------
# Key Vault and cloud witness storage account
#
# Both resources are created by Terraform before the AVM module runs.
# The names must be globally unique. The Key Vault uses purge_protection_enabled
# = false so it can be deleted and recreated with the same name after
# terraform destroy (the provider purges the soft-deleted vault automatically).
# ---------------------------------------------------------------------------

keyvault_name                = "kv-azlocal-lab"
witness_storage_account_name = "saazlocallab"

# ---------------------------------------------------------------------------
# Network adapters
#
# management_adapters must match the NIC names configured inside the Azure
# Local OS by scripts/01Lab/02_Cluster.ps1 (MGMT1 and MGMT2 in the default lab).
#
# rdma_enabled = false is correct for this single-node lab:
#   - No cross-node storage traffic exists (switchless storage).
#   - MGMT1 and MGMT2 are virtual adapters in a nested Hyper-V VM and do
#     not support hardware RDMA.
# ---------------------------------------------------------------------------

# The portal ARM template uses a single adapter (MGMT1) with a Compute_Management
# intent and no storage network (managementComputeOnly / singleServerDeployment pattern).
# The AVM module requires at least one entry in storage_networks to produce a converged
# intent (converged = true when storage_adapters == management_adapters). With an empty
# list the module generates two separate intents where the storage intent has zero
# adapters, which fails Azure Local schema validation.
# Workaround: keep MGMT1 in storage_networks to force converged = true, then override
# traffic_type and intent_name below to match the portal's single-intent pattern.
management_adapters             = ["MGMT1"]
rdma_enabled                    = false
storage_connectivity_switchless = true
storage_networks = [
  { name = "MGMT1", networkAdapterName = "MGMT1", vlanId = "711" }
]

# Network intent — matches the portal ARM template exactly:
#   name: "Compute_Management", trafficType: ["Compute", "Management"], adapter: ["MGMT1"]
intent_name  = "Compute_Management"
traffic_type = ["Compute", "Management"]

# Networking type and pattern, present in the QuickStart ARM template but rejected
# by the live API (ObjectAdditionalProperties). Set to "" to omit from the payload.
networking_type    = ""
networking_pattern = ""

# Set to true when a previous terraform apply created deploymentSettings in Azure
# but timed out before saving state (e.g. "context deadline exceeded").
# Set to false on a fresh environment where deploymentSettings does not yet exist.
import_deployment_settings = false

# Populate with the role assignment GUIDs from a 409 RoleAssignmentExists error
# when a previous apply created these but the state was lost before saving.
# Keys: "<SERVER>_DMR" and "<SERVER>_INFRA". Values: GUIDs from the error output.
# Reset to {} after a successful apply.
import_machine_rg_role_assignment_ids = {}


# ---------------------------------------------------------------------------
# Deployment mode — see deployment flow at the top of this file
#
# true  = Deploy   (default, recommended)
# false = Validate only (optional, to check configuration before deploying)
# ---------------------------------------------------------------------------

is_exported = true

# ---------------------------------------------------------------------------
# Deployment options
# ---------------------------------------------------------------------------

configuration_mode        = "Express"
bitlocker_boot_volume     = false
bitlocker_data_volumes    = false
enable_telemetry          = true

# Security — matches the portal's Customized security settings.
credential_guard_enforced = true

# Observability — set to true for EU-region deployments.
eu_location = true

# Quorum witness — the portal ARM template uses no witness for single-node.
# The AVM module still passes cloudAccountName to the API (module limitation)
# but witnessType = "" means Azure will not use it for quorum.
witness_type = ""
