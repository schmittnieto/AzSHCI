# terraform.tfvars.example
#
# Copy this file to terraform.tfvars and fill in every value marked with
# TODO before running terraform plan or terraform apply.
#
# IMPORTANT: terraform.tfvars contains sensitive values (passwords, secrets).
# It is listed in .gitignore — never commit the populated file to source control.
#
# ---------------------------------------------------------------------------
# DEPLOYMENT FLOW
#
# Stage 1 — Validate (is_exported = false)
#   terraform init && terraform apply
#   Creates Key Vault, storage account, assigns roles, registers edgeDevices,
#   then validates the Azure Local deployment configuration (~60 minutes).
#   Review the result in the Azure portal before proceeding.
#
# Stage 2 — Deploy  (is_exported = true)
#   Change is_exported to true, then: terraform apply
#   Triggers full cluster provisioning (~180 minutes).
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# Module toggle
# ---------------------------------------------------------------------------

# Set to false before terraform destroy when the Arc node has been manually
# deleted from Azure. This skips the cluster module entirely.
enable_cluster_module = true

# ---------------------------------------------------------------------------
# Azure subscription and resource group
# ---------------------------------------------------------------------------

# TODO: replace with your Azure subscription ID
subscription_id     = "00000000-0000-0000-0000-000000000000"
resource_group_name = "rg-azlocal-lab"

# ---------------------------------------------------------------------------
# Cluster identity
# ---------------------------------------------------------------------------

# cluster_name becomes both the Azure resource name and the internal cluster name.
# site_id is used as namingPrefix (e.g. "HCI01").
cluster_name         = "azure-local"
site_id              = "HCI01"
custom_location_name = "azlocal-customlocation"

# ---------------------------------------------------------------------------
# Active Directory
# ---------------------------------------------------------------------------

# Domain promoted by scripts/01Lab/01_DC.ps1
domain_fqdn = "azurelocal.local"

# OU pre-created by New-HciAdObjectsPreCreation in 01_DC.ps1
adou_path = "OU=HCI,OU=Servers,OU=_LAB,DC=azurelocal,DC=local"

# ---------------------------------------------------------------------------
# Credentials
#
# WARNING: these are intentional lab defaults — change before running and
# never commit real credentials to source control.
# ---------------------------------------------------------------------------

# LCM deployment user created inside the domain by 01_DC.ps1
deployment_user          = "hciadmin"
deployment_user_password = "TODO-change-me"

# Local administrator account on the Azure Local node (created by 02_Cluster.ps1)
local_admin_user     = "Setupuser"
local_admin_password = "TODO-change-me"

# ---------------------------------------------------------------------------
# Network
#
# Values must match the static IP configuration applied by 02_Cluster.ps1.
# The starting/ending range reserves infrastructure IPs (VIPs, LB addresses).
# Keep it outside the node IP.
# ---------------------------------------------------------------------------

default_gateway  = "172.19.18.1"
dns_servers      = ["172.19.18.2"]
starting_address = "172.19.18.20"
# Azure Local requires ~6 infrastructure IPs for single-node deployments.
ending_address = "172.19.18.26"
subnet_mask    = "255.255.255.0"

# ---------------------------------------------------------------------------
# Servers
#
# One entry per Arc-registered node. Single-node lab: only AZLN01.
# ---------------------------------------------------------------------------

servers = [
  {
    name        = "AZLN01"
    ipv4Address = "172.19.18.10"
  }
]

# ---------------------------------------------------------------------------
# Service principals
# ---------------------------------------------------------------------------

# SPN created by scripts/01Lab/00_AzurePreRequisites.ps1.
# TODO: replace with the AppId and secret from 00_AzurePreRequisites.ps1 output
service_principal_id     = "00000000-0000-0000-0000-000000000000"
service_principal_secret = "TODO-your-spn-client-secret"

# Object ID of the built-in Microsoft.AzureStackHCI resource provider SPN.
# Required for the "Azure Connected Machine Resource Manager" role assignment
# that enables Arc extension installation.
# Retrieve with: (Get-AzADServicePrincipal -ApplicationId "1412d89f-b8a8-4111-b4fd-e82905cbd85d").Id
# TODO: replace with the value from the command above
rp_service_principal_object_id = "00000000-0000-0000-0000-000000000000"

# ---------------------------------------------------------------------------
# Key Vault and cloud witness storage account
#
# Base name prefixes only. A random 4-digit integer is appended automatically
# by main.tf on the first apply and kept stable in state.
# Example: kv-azlocal-lab3847, saazlocallab3847
# ---------------------------------------------------------------------------

keyvault_name                = "kv-azlocal-lab"
witness_storage_account_name = "saazlocallab"

# ---------------------------------------------------------------------------
# Network adapters
#
# management_adapters must match the NIC names configured inside the Azure
# Local OS by 02_Cluster.ps1. MGMT1 only for single-node (portal pattern).
#
# rdma_enabled = false: single-node lab NICs are virtual Hyper-V adapters,
# no hardware RDMA support.
# ---------------------------------------------------------------------------

management_adapters             = ["MGMT1"]
rdma_enabled                    = false
storage_connectivity_switchless = true

# MGMT1 listed in storage_networks to force converged intent (management +
# compute on the same adapter). Matches portal's managementComputeOnly pattern.
storage_networks = [
  { name = "MGMT1", networkAdapterName = "MGMT1", vlanId = "711" }
]

# Network intent — matches the portal ARM template exactly:
#   name: "Compute_Management", trafficType: ["Compute", "Management"], adapter: ["MGMT1"]
intent_name  = "Compute_Management"
traffic_type = ["Compute", "Management"]

# Networking type and pattern — rejected by the live API (ObjectAdditionalProperties).
# Set to "" to omit from the payload.
networking_type    = ""
networking_pattern = ""

# ---------------------------------------------------------------------------
# Import helpers
#
# Use these when a previous terraform apply created resources in Azure but
# the state was lost before saving (e.g. context deadline exceeded).
# Reset to false / {} after a successful apply.
# ---------------------------------------------------------------------------

# Set to true when deploymentSettings/default already exists in Azure.
import_deployment_settings = false

# Populate with the role assignment GUIDs from a 409 RoleAssignmentExists error.
# Keys: "<SERVER>_DMR" and "<SERVER>_INFRA". Values: GUIDs from the error output.
import_machine_rg_role_assignment_ids = {}

# ---------------------------------------------------------------------------
# Deployment mode — see flow at the top of this file
#
# false = Validate (Stage 1, start here)
# true  = Deploy   (Stage 2, change after successful validation)
# ---------------------------------------------------------------------------

is_exported = false

# Set to true only after a successful full deployment (all steps completed).
# Keep false while deploying or retrying — arcbridge and customlocation
# do not exist until all deployment steps have succeeded.
deployment_completed = false

# ---------------------------------------------------------------------------
# Deployment options
# ---------------------------------------------------------------------------

configuration_mode        = "Express"
bitlocker_boot_volume     = false
bitlocker_data_volumes    = false
enable_telemetry          = true

# Security — matches the portal's Customized security settings.
credential_guard_enforced = true

# Observability — set to true for EU-region deployments.
eu_location = false

# Quorum witness — the portal ARM template uses no witness for single-node.
# witnessType = "" means Azure will not use it for quorum.
witness_type = ""
